{
  "name": "sf-tennis",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Create D1 database: wrangler d1 create sf-tennis-db
  // Then update the database_id below
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sf-tennis-db",
      "database_id": "TODO_REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
